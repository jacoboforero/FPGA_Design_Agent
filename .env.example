# RabbitMQ broker URL (matches infrastructure/docker-compose.yml defaults)
RABBITMQ_URL=amqp://user:password@localhost:5672/

# LLM runtime behavior is configured in config/runtime.yaml.
# Keep USE_LLM for legacy/UI paths that still gate LLM access via env.
USE_LLM=0
OPENAI_API_KEY=replace-with-your-openai-key
GROQ_API_KEY=replace-with-your-groq-key
ANTHROPIC_API_KEY=replace-with-your-anthropic-key
GOOGLE_API_KEY=replace-with-your-google-key
COHERE_API_KEY=replace-with-your-cohere-key
XAI_API_KEY=replace-with-your-xai-key
# Ollama base URL for qwen-local provider
OLLAMA_BASE_URL=http://localhost:11434
# Optional OpenAI routing mode: auto (recommended), chat, responses
OPENAI_API_MODE=auto

# Tooling paths (overrides)
VERILATOR_PATH=verilator
IVERILOG_PATH=iverilog
VVP_PATH=vvp
# Testbench lint hardening: compile lint + lightweight semantic checks
TB_LINT_SEMANTIC=1
# If set to 0, semantic findings are warnings and do not fail tb_lint
TB_LINT_SEMANTIC_STRICT=1

# RabbitMQ connection robustness
RABBITMQ_HEARTBEAT=600
RABBITMQ_BLOCKED_CONNECTION_TIMEOUT=300
RABBITMQ_CONNECTION_ATTEMPTS=5
RABBITMQ_RETRY_DELAY=2
RABBITMQ_SOCKET_TIMEOUT=10
RABBITMQ_RECONNECT_DELAY=1.0

# CLI queue hygiene and planning timeout
CLI_PURGE_QUEUES=1
CLI_PLANNER_TIMEOUT_S=60
# Optional terminal theme for spec-helper UI: auto (default), light, dark, neutral
# CLI_THEME=auto
