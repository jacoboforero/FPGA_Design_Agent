# RabbitMQ broker URL (matches infrastructure/docker-compose.yml defaults)
RABBITMQ_URL=amqp://user:password@localhost:5672/

# Enable LLM-backed generation (optional)
USE_LLM=0
# Default LLM provider (openai|anthropic|google|groq|qwen-local)
DEFAULT_LLM_PROVIDER=openai
OPENAI_API_KEY=replace-with-your-key
# Default LLM model (e.g., gpt-5.2, gpt-5.1, gpt-4o)
DEFAULT_LLM_MODEL=gpt-5.2
# Per-agent overrides (optional): set provider/model for a specific agent
# Recommended (canonical) format: {AGENT}_LLM_PROVIDER and {AGENT}_LLM_MODEL
# Examples (preferred prefix-style):
# SPEC_HELPER_LLM_PROVIDER=openai
# SPEC_HELPER_LLM_MODEL=gpt-5-nano
# PLANNER_LLM_PROVIDER=qwen-local
# DEBUG_LLM_PROVIDER=anthropic
# Groq settings (if provider=groq)
GROQ_API_KEY=replace-with-your-groq-key

# Tooling paths (overrides)
VERILATOR_PATH=verilator
IVERILOG_PATH=iverilog
VVP_PATH=vvp
