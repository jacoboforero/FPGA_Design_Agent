# RabbitMQ broker URL (matches infrastructure/docker-compose.yml defaults)
RABBITMQ_URL=amqp://user:password@localhost:5672/

# Enable LLM-backed generation (optional)
USE_LLM=0
# LLM provider: openai (default) or groq
LLM_PROVIDER=openai
OPENAI_API_KEY=replace-with-your-key
# Optional: override model (e.g., gpt-4.1-mini, gpt-4o, gpt-5-nano)
OPENAI_MODEL=gpt-4.1-mini
# Optional API routing: auto (recommended), chat, responses
OPENAI_API_MODE=auto
# Optional: override narrative model independently from OPENAI_MODEL
NARRATIVE_MODEL=
# Optional fallback when OPENAI_MODEL is GPT-5 and NARRATIVE_MODEL is unset
NARRATIVE_FALLBACK_MODEL=gpt-4.1-mini
# Optional: override spec-helper model used during interactive spec completion
SPEC_HELPER_MODEL=
# Optional narrative latency/verbosity controls
NARRATIVE_LLM_TIMEOUT_S=10
NARRATIVE_MAX_TOKENS=220
NARRATIVE_TEMPERATURE=0.5
# Groq settings (if LLM_PROVIDER=groq)
GROQ_API_KEY=replace-with-your-groq-key
GROQ_MODEL=llama-3.1-8b-instant

# Tooling paths (overrides)
VERILATOR_PATH=verilator
IVERILOG_PATH=iverilog
VVP_PATH=vvp
# Testbench lint hardening: compile lint + lightweight semantic checks
TB_LINT_SEMANTIC=1
# If set to 0, semantic findings are warnings and do not fail tb_lint
TB_LINT_SEMANTIC_STRICT=1

# RabbitMQ connection robustness
RABBITMQ_HEARTBEAT=600
RABBITMQ_BLOCKED_CONNECTION_TIMEOUT=300
RABBITMQ_CONNECTION_ATTEMPTS=5
RABBITMQ_RETRY_DELAY=2
RABBITMQ_SOCKET_TIMEOUT=10
RABBITMQ_RECONNECT_DELAY=1.0

# CLI queue hygiene and planning timeout
CLI_PURGE_QUEUES=1
CLI_PLANNER_TIMEOUT_S=60
